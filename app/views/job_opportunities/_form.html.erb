<%= simple_form_for(@job_opportunity, defaults: { input_html: { class: "shadow appearance-none border border-red-500 rounded w-full py-2 px-3 text-gray-700 mb-3 leading-tight focus:outline-none focus:shadow-outline" } }) do |f| %>
  <%= f.input :job_title %>
  <%= f.input :job_level, as: :select, collection: ['Júnior', 'Pleno', 'Sênior'] %>
  <%= f.input :salary_range %>
  <%= f.input :place %>
  <%= f.input :description, as: :text %>
  <%= f.input :limit_date, as: :string %>
  <%= f.input :number_of_positions %>
  <%= f.submit @job_opportunity.new_record? ? 'Cadastrar vaga' : 'Atualizar' %>
<% end %>